# Codicel backend configuration
# Copy this file to .env and fill in your values.

# OpenAI API key (from your OpenAI Build Week free Codex credits, or your own account)
OPENAI_API_KEY=sk-...

# Model used for repository reasoning. Swap to whatever GPT-5.6 model string
# OpenAI provides you access to under the Build Week credits.
CODICEL_MODEL=gpt-5.6

# Optional: GitHub token, raises the API rate limit for pulling PR/issue metadata
# on the demo repository. Not required for public repos at low request volume.
GITHUB_TOKEN=

# Host/port for the API server
CODICEL_HOST=0.0.0.0
CODICEL_PORT=8000
