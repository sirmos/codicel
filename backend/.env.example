# Codicel backend configuration
# Copy this file to .env and fill in your values.

# --- While testing with Groq (free), before OpenAI billing is set up ---
# Uncomment these three lines and get a free key at console.groq.com
# CODICEL_API_BASE=https://api.groq.com/openai/v1
# CODICEL_API_KEY=gsk_...
# CODICEL_MODEL=llama-3.3-70b-versatile

# --- For the real submission, using OpenAI GPT-5.6 ---
# Leave CODICEL_API_BASE unset (or comment it out) to use OpenAI directly.
OPENAI_API_KEY=sk-...
CODICEL_MODEL=gpt-5.6

# Optional: GitHub token, raises the API rate limit for pulling PR/issue metadata
# on the demo repository. Not required for public repos at low request volume.
GITHUB_TOKEN=

# Host/port for the API server
CODICEL_HOST=0.0.0.0
CODICEL_PORT=8000
